{
  "manifest_version": 3,
  "name": "Phishing Shield",
  "version": "1.0.0",
  "description": "Real-time phishing website detection powered by Machine Learning. Scans the URL of every tab you visit.",
  "permissions": ["activeTab", "tabs"],
  "host_permissions": ["http://localhost:5000/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}
